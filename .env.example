# Copy to .env.local and fill machine-specific / sensitive values.
# Example:
#   cp .env.example .env.local
# Many defaults now come from .env.shared and scripts/load_env.sh,
# so this template keeps only the most important local overrides active.

# Required local values

# Actual GCP project ID (not project number)
GCP_PROJECT="your-gcp-project-id"

# Artifact Registry repository name
AR_REPO="your-artifact-registry-repo"

# Orchestrator Cloud Run service name
ORCH_SERVICE="your-orchestrator-service-name"

# Drive configuration
DRIVE_ROOT_FOLDER_ID="your-drive-root-folder-id"
DRIVE_BENCHMARK_RUNS_FOLDER_ID="your-drive-benchmark-runs-folder-id"

# Keep secret files outside the repo for local tooling.
CGH_SECRETS_ROOT="$HOME/.config/cgh-roster"
DRIVE_OAUTH_CLIENT_CREDENTIALS_FILE="$CGH_SECRETS_ROOT/drive/oauth_client_credentials.json"
DRIVE_OAUTH_TOKEN_FILE="$CGH_SECRETS_ROOT/drive/oauth_token.json"
WORKER_TOKEN_FILE="$CGH_SECRETS_ROOT/cloud-run/worker_token.txt"
ORCHESTRATOR_AUTH_TOKEN_FILE="$CGH_SECRETS_ROOT/cloud-run/orchestrator_auth_token.txt"

# Optional explicit worker URL for launcher/orchestrator use.
# Leave blank for normal real deploys; the deploy script resolves the
# current worker URL from Cloud Run. Set this for dry-run previews or
# if you want to override the resolved worker endpoint explicitly.
# WORKER_URL="https://your-worker-service-xxxx.a.run.app"

# Optional direct secret overrides if you are not using *_FILE indirection.
# WORKER_TOKEN="replace-me"
# ORCHESTRATOR_AUTH_TOKEN="replace-me"

# Optional repo/deploy overrides.
# Defaults already come from .env.shared unless your repo layout or
# naming differs from the standard configuration.
# IMAGE_TAG="manual-tag"
# WORKER_SOURCE_DIR="worker"
# ORCH_SOURCE_DIR="orchestrator"
# WORKER_DOCKERFILE="worker/Dockerfile"
# ORCH_DOCKERFILE="orchestrator/Dockerfile"
# WORKER_SERVICE="cgh-roster-trial-compute-worker"
# REGION="asia-southeast1"
# DRIVE_BENCHMARK_RUNS_FOLDER_NAME="benchmark_runs"

# Optional deploy tuning
# WORKER_SERVICE_ACCOUNT="worker-sa@your-gcp-project-id.iam.gserviceaccount.com"
# ORCH_SERVICE_ACCOUNT="orchestrator-sa@your-gcp-project-id.iam.gserviceaccount.com"
# WORKER_MEMORY="512Mi"
# ORCH_MEMORY="1Gi"
# WORKER_CPU="1"
# ORCH_CPU="1"
# WORKER_TIMEOUT="300s"
# ORCH_TIMEOUT="3600s"
# WORKER_CONCURRENCY="80"
# ORCH_CONCURRENCY="1"
# WORKER_MIN_INSTANCES="0"
# ORCH_MIN_INSTANCES="0"
# WORKER_MAX_INSTANCES="3"
# ORCH_MAX_INSTANCES="1"
# WORKER_ALLOW_UNAUTHENTICATED="true"
# ORCH_ALLOW_UNAUTHENTICATED="false"

# Optional orchestrator runtime tuning
# ORCHESTRATOR_OUTPUT_ROOT="tmp/phase14_campaigns"
# ORCHESTRATOR_CHUNK_TRIALS="1000"
# ORCHESTRATOR_TOP_N="10"
# ORCHESTRATOR_REQUEST_TIMEOUT_MS="600000"
# ORCHESTRATOR_STATUS_POLL_INTERVAL_MS="2000"

# Only set these after you have a real Cloud Run runtime file/mount strategy
# for the orchestrator. Any orchestrator deploy command, including DRY_RUN
# previews, refuses to continue until these runtime paths are set to absolute
# container paths.
# ORCH_DRIVE_OAUTH_CLIENT_CREDENTIALS_RUNTIME_FILE="/var/run/cgh-roster/drive/oauth_client_credentials.json"
# ORCH_DRIVE_OAUTH_TOKEN_RUNTIME_FILE="/var/run/cgh-roster/drive/oauth_token.json"
